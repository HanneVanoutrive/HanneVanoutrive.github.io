@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

<#Person> a rdfs:Class ;
    rdfs:label "Person"@en, "Persoon"@nl;
    rdfs:comment "A person (alive, dead, undead, or fictional)."@en ;
    owl:equivalentClass <https://xmlns.com/foaf/spec/#term_Person>.

<#AdministratieveEenheid> a rdfs:Class;
    rdfs:label "Administratieve Eenheid"@nl;
    rdfs:comment "Bestuurlijke eenheid waar een lidstaat rechtsbevoegdheid heeft en/of uitoefent, in het kader van lokaal, regionaal of nationaal bestuur."@nl.

<#Course> a rdfs:Class ;
    rdfs:label "Course" ;
    rdfs:comment "A course offered at an educational institution." .

<#Photograph> a rdfs:Class ;
    rdfs:label "Photograph"@en, "Foto"@nl;
    rdfs:comment "A photograph is a visual representation created by capturing light (or other electromagnetic radiation) on a photosensitive or digital medium at a specific time, resulting in an image that depicts a real‑world scene, object, or event."@en ;
    owl:equivalentClass <https://xmlns.com/foaf/spec/#term_Image> .

<#Place> a rdfs:Class ;
    rdfs:label "Place"@en, "Locatie"@nl ;
    rdfs:comment "A geographic location or named place in the real world."@en .

<#name> a rdf:Property;
    rdfs:label "Name"@en, "Naam"@nl;
    rdfs:comment "Official  name for a Person or organisation"@en;
    rdfs:domain rdfs:Resource ;
    rdfs:range rdfs:Literal .

<#knows> a rdf:Property;
    rdfs:label "knows"@en, "kent"@nl, "connaît"@fr;
    rdfs:comment "A person known by this person (indicating some level of reciprocated interaction between the parties)."@en ;
    rdfs:domain <#Person> ;
    rdfs:range rdfs:Resource.

<#birthPlace> a rdf:Property;
    rdfs:label "Birthplace"@en, "Geboorteplaats"@nl;
    rdfs:comment "City where person was born."@en;
    rdfs:domain <#Person> ;
    rdfs:range rdfs:Resource .

<#nationality> a rdf:Property;
    rdfs:label "Nationality"@en, "Nationaliteit"@nl;
    rdfs:comment "Reference to a country where a Person was born or resettled"@en;
    rdfs:domain <#Person> ;
    rdfs:range rdfs:Resource .

<#jobTitle> a rdf:Property;
    rdfs:label "Job Title"@en, "Beroep"@nl;
    rdfs:comment "The official name of a person’s position or role within an organization, which describes their main duties and level of responsibility."@en;
    rdfs:domain <#Person> ;
    rdfs:range rdfs:Literal .

<#employer> a rdf:Property;
    rdfs:label "Employer"@en, "Werkgever"@nl;
    rdfs:comment "A company, or organization that hires people to work for them and pays them for their work."@en;
    rdfs:domain <#Person> ;
    rdfs:range <#AdministratieveEenheid>.

<#owns> a rdf:Property;
    rdfs:label "Owns"@en, "Bezit"@nl;
    rdfs:comment "Has legal possession or control of something; to have something as your property."@en;
    rdfs:domain rdfs:Resource ;
    rdfs:range rdfs:Resource .

<#enrolledIn> a rdf:Property ;
    rdfs:label "enrolled in" ;
    rdfs:comment "Relates a person to a course they are enrolled in." ;
    rdfs:domain <#Person> ;
    rdfs:range <#Course> .

<#seeAlso> a rdf:Property ;
    rdfs:label "see also" ;
    rdfs:comment "Relates a resource to another resource that describes the same thing." ;
    rdfs:domain rdfs:Resource ;
    rdfs:range rdfs:Resource .

<#photographer> a rdf:Property ;
    rdfs:label "photographer"@en, "fotograaf"@nl ;
    rdfs:comment "A property that links a photograph (or image) to the person or organization that was primarily responsible for creating the photograph by capturing the image." ;
    rdfs:domain <#Photograph> ;
    rdfs:range <#Person> .

<#depictsPerson> a rdf:Property ;
    rdfs:label "depicts person"@en ;
    rdfs:comment "Links a photograph to a person who is visually depicted in the image."@en ;
    rdfs:subPropertyOf foaf:depicts ;
    rdfs:domain <#Photograph> ;
    rdfs:range <#Person> .

<#photographLocation> a rdf:Property ;
    rdfs:label "photograph location"@en ;
    rdfs:comment "The geographic location where the photograph was taken."@en ;
    rdfs:domain <#Photograph> ;
    rdfs:range <#Place>.

<#description> a rdf:Property ;
    rdfs:label "photograph description"@en ;
    rdfs:comment "A textual description of the visual content of a photograph."@en ;
    rdfs:domain <#Photograph> ;
    rdfs:range rdf:langString .





